<Project Sdk="Microsoft.DotNet.Helix.Sdk">

  <ItemGroup>
    <!-- Both queues run the JIT path (today's behaviour). The NativeAOT path
         (UseXHarnessAotPayload=true) skips amd64 because the published binary
         is osx-arm64 only - it would not execute on amd64 hardware. -->
    <HelixTargetQueue Include="osx.15.amd64.open" Condition="'$(UseXHarnessAotPayload)' != 'true'">
      <TestArch>x64</TestArch>
      <iOSSimulatorVersionUnderTest>18.1</iOSSimulatorVersionUnderTest>
    </HelixTargetQueue>
    <HelixTargetQueue Include="osx.26.arm64.open">
      <TestArch>arm64</TestArch>
      <!-- Leave iOSSimulatorVersionUnderTest empty: let xharness pick whichever
           iOS simulator ships with the arm64 worker's Xcode, so we don't have
           to chase Xcode image bumps for this proj. -->
    </HelixTargetQueue>
  </ItemGroup>

  <PropertyGroup>
    <TestAppBundleName>System.Numerics.Vectors.Tests</TestAppBundleName>
  </PropertyGroup>

  <!--
    Build one XHarnessAppBundleToTest per HelixTargetQueue. We can't rely on
    $(HelixTargetQueue) being populated here (CreateAppleWorkItems runs in the
    outer MSBuild invocation, before the Helix SDK dispatches one Test run per
    queue), so iterate the items directly via the batched metadata syntax.
    %(HelixTargetQueue.TestArch) and %(HelixTargetQueue.iOSSimulatorVersionUnderTest)
    are queue-specific metadata defined in the ItemGroup above.
  -->
  <Target Name="TestApple" BeforeTargets="CoreTest"
          Outputs="%(HelixTargetQueue.Identity)">
    <PropertyGroup>
      <_CurrentTestArch>%(HelixTargetQueue.TestArch)</_CurrentTestArch>
      <_CurrentSimVersion>%(HelixTargetQueue.iOSSimulatorVersionUnderTest)</_CurrentSimVersion>
      <_CurrentTestTargetSuffix Condition="'$(_CurrentSimVersion)' != ''">_$(_CurrentSimVersion)</_CurrentTestTargetSuffix>
      <_CurrentAppUrl>$(AssetsBaseUri)/ios/test-app-new/ios-simulator-64/$(_CurrentTestArch)/$(TestAppBundleName).app.zip</_CurrentAppUrl>
      <_CurrentAppDir>$(ArtifactsTmpDir)test-app-new\ios-simulator-64\$(_CurrentTestArch)</_CurrentAppDir>
    </PropertyGroup>

    <Error Condition="'$(_CurrentTestArch)' == ''"
           Text="HelixTargetQueue '%(HelixTargetQueue.Identity)' has no TestArch metadata." />

    <DownloadFile SourceUrl="$(_CurrentAppUrl)" DestinationFolder="$(_CurrentAppDir)" SkipUnchangedFiles="True" Retries="5">
      <Output TaskParameter="DownloadedFile" ItemName="_ZippedAppBundle" />
    </DownloadFile>

    <Message Text="Downloaded $(TestAppBundleName) ($(_CurrentTestArch)) from @(_ZippedAppBundle). Extracting..." Importance="High" />
    <Exec Command="tar -xzf @(_ZippedAppBundle) -C $(_CurrentAppDir)" />

    <ItemGroup>
      <XHarnessAppBundleToTest Include="$(_CurrentAppDir)\$(TestAppBundleName).app">
        <TestTarget>ios-simulator-64$(_CurrentTestTargetSuffix)</TestTarget>
        <WorkItemTimeout>00:20:00</WorkItemTimeout>
        <TestTimeout>00:07:00</TestTimeout>
        <LaunchTimeout>00:03:30</LaunchTimeout>
        <CustomCommands>
        <![CDATA[
          set -ex
          xharness apple simulators install $target --verbosity=Debug
          xharness apple simulators reset-simulator --output-directory="$output_directory" --target=$target --verbosity=Debug
          deviceId=`xharness apple device $target`
          xharness apple test -t=$target --device="$deviceId" -o="$output_directory" --app="$app" --launch-timeout=$launch_timeout --timeout=$timeout -v
          result=$?
          # Uninstall may fail if 'apple test' already cleaned up the simulator - don't fail the test for that
          xharness apple uninstall -t=$target --device="$deviceId" -o="$output_directory" --app="net.dot.$(TestAppBundleName)" -v || true
          exit $result
        ]]>
        </CustomCommands>
      </XHarnessAppBundleToTest>
    </ItemGroup>
  </Target>

</Project>
